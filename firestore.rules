rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth check helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    // User profile: only own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Stocks: Everyone can read, only Admin/System can write (for now allow all in dev)
    match /stocks/{stockId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /price_history/{pointId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }
    
    // Portfolio: Each doc has userId, restrict to own docs
    match /portfolio/{holdingId} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }
    
    // Transactions: Same as portfolio
    match /transactions/{transId} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }
    
    // Posts & Social
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
